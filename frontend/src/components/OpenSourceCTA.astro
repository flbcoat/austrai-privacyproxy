---
---
<section class="section open-source" id="open-source">
  <div class="container">
    <div class="oss-wrapper">
      <div class="oss-content">
        <span class="section-label">Community</span>
        <h2>Open Source.<br /><span class="text-gradient">Made in Austria.</span></h2>
        <p class="oss-desc">
          PrivacyProxy ist ein Open-Source-Projekt aus Österreich. Der gesamte Code ist öffentlich einsehbar, auditierbar und erweiterbar. Kein Vendor-Lock-in, keine versteckten Kosten.
        </p>

        <ul class="oss-features">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" aria-hidden="true"><polyline points="20,6 9,17 4,12"/></svg>
            <span><strong>MIT-Lizenz</strong> — Frei nutzbar, auch kommerziell</span>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" aria-hidden="true"><polyline points="20,6 9,17 4,12"/></svg>
            <span><strong>Österreichische Datenmuster</strong> — SVNr, UID, Firmenbuch, IBAN</span>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" aria-hidden="true"><polyline points="20,6 9,17 4,12"/></svg>
            <span><strong>EU-gehostetes LLM</strong> — Mistral AI, kein US-Cloud-Zwang</span>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" aria-hidden="true"><polyline points="20,6 9,17 4,12"/></svg>
            <span><strong>Kein Logging</strong> — Keine Daten werden gespeichert</span>
          </li>
        </ul>

        <div class="oss-actions">
          <a href="https://github.com/florianbieche/privacyproxy" class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Auf GitHub ansehen
          </a>
        </div>
      </div>

      <div class="oss-tech">
        <h4>Tech Stack</h4>
        <div class="oss-pills">
          <span class="pill">Python</span>
          <span class="pill">FastAPI</span>
          <span class="pill">Presidio</span>
          <span class="pill">SpaCy</span>
          <span class="pill pill-purple">Astro</span>
          <span class="pill pill-purple">LiteLLM</span>
          <span class="pill">Docker</span>
          <span class="pill">Hetzner</span>
        </div>

        <div class="oss-architecture">
          <h4>Architektur</h4>
          <div class="oss-arch-diagram">
            <div class="oss-arch-box">
              <span class="oss-arch-label">Frontend</span>
              <span class="oss-arch-tech">Astro (Static)</span>
            </div>
            <div class="oss-arch-arrow" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </div>
            <div class="oss-arch-box oss-arch-box-accent">
              <span class="oss-arch-label">PrivacyProxy API</span>
              <span class="oss-arch-tech">FastAPI + Presidio</span>
            </div>
            <div class="oss-arch-arrow" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </div>
            <div class="oss-arch-box oss-arch-box-purple">
              <span class="oss-arch-label">LLM (Mistral)</span>
              <span class="oss-arch-tech">via LiteLLM</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .open-source {
    position: relative;
    overflow: hidden;
  }

  .open-source::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-border), transparent);
  }

  .oss-wrapper {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .oss-desc {
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-top: 1.25rem;
  }

  .oss-features {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .oss-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .oss-features li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .oss-features li strong {
    color: var(--color-text);
  }

  .oss-actions {
    margin-top: 2.5rem;
  }

  .oss-tech {
    padding-top: 1rem;
  }

  .oss-tech h4 {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .oss-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .oss-architecture {
    margin-top: 0;
  }

  .oss-arch-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .oss-arch-box {
    width: 100%;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    text-align: center;
  }

  .oss-arch-box-accent {
    border-color: rgba(6, 182, 212, 0.3);
    box-shadow: 0 0 12px rgba(6, 182, 212, 0.08);
  }

  .oss-arch-box-purple {
    border-color: rgba(139, 92, 246, 0.3);
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.08);
  }

  .oss-arch-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .oss-arch-tech {
    display: block;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-dim);
    margin-top: 0.2rem;
  }

  .oss-arch-arrow {
    color: var(--color-text-dim);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .oss-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
