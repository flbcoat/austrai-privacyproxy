  // ==========================================
  // File validation & selection
  // ==========================================
  function validateFile(file) {
    const ext = getFileExtension(file.name);
    if (!ACCEPTED_EXTENSIONS.includes(ext)) {
      return 'Nicht unterstütztes Dateiformat: ' + ext + '. Erlaubt sind: ' + ACCEPTED_EXTENSIONS.join(', ');
    }
    if (file.size > MAX_FILE_SIZE) {
      return 'Datei ist zu groß (' + formatFileSize(file.size) + '). Maximum: 10 MB.';
    }
    if (file.size === 0) {
      return 'Die Datei ist leer.';
    }
    return null;
  }

  function selectFile(file) {
    const error = validateFile(file);
    if (error) {
      alert(error);
      return;
    }
    selectedFile = file;
    fileIcon.innerHTML = getFileTypeIcon(file.name);
    fileName.textContent = file.name;
    fileSize.textContent = formatFileSize(file.size);
    dropzone.style.display = 'none';
    fileInfo.style.display = 'flex';
    updateStartButton();
  }

  function clearFile() {
    selectedFile = null;
    fileInput.value = '';
    dropzone.style.display = '';
    fileInfo.style.display = 'none';
    updateStartButton();
  }

  // ==========================================
  // API calls — single call to /api/process
  // ==========================================
  function getDenyList() {
    if (!denylistEl) return null;
    const val = denylistEl.value.trim();
    if (!val) return null;
    const items = val.split('\n').map(s => s.trim()).filter(s => s.length > 0);
    return items.length > 0 ? items : null;
  }

  async function callProcess(text, prompt) {
    const body = { text: text };
    if (prompt && prompt.trim()) body.prompt = prompt.trim();
    const denyList = getDenyList();
    if (denyList) body.deny_list = denyList;

    const resp = await fetch(API_BASE + '/api/process', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (!resp.ok) {
      const errData = await resp.json().catch(() => ({}));
      throw new Error(errData.detail || 'Verarbeitung fehlgeschlagen (HTTP ' + resp.status + ')');
    }
    return resp.json();
  }

  async function callUpload(file, prompt) {
    const formData = new FormData();
    formData.append('file', file);
    if (prompt && prompt.trim()) formData.append('prompt', prompt.trim());
    const denyList = getDenyList();
    if (denyList) formData.append('deny_list', denyList.join('\n'));

    const resp = await fetch(API_BASE + '/api/upload', {
      method: 'POST',
      body: formData
    });
    if (!resp.ok) {
      const errData = await resp.json().catch(() => ({}));
      throw new Error(errData.detail || 'Dateiverarbeitung fehlgeschlagen (HTTP ' + resp.status + ')');
    }
    return resp.json();
  }

  // Helper: wait ms
  function wait(ms) {
    return new Promise(r => setTimeout(r, ms));
  }

  // ==========================================
  // Build Step 0 content for file uploads
  // ==========================================
  function buildFileStep0(data) {
    let html = '';

    // Metadata warnings
    if (data.metadata_warnings && data.metadata_warnings.length > 0) {
      html += '<div class="demo-metadata-warnings">';
      html += '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
      html += '<div>' + escapeHtml(data.metadata_warnings.join('; ')) + '</div>';
      html += '</div>';
    }

    // Extracted text note
    const formatLabel = selectedFile ? getFileFormatLabel(selectedFile.name) : 'Datei';
    let noteText = formatLabel + ' verarbeitet';
    if (data.page_count) {
      noteText += ' (' + data.page_count + (data.page_count === 1 ? ' Seite' : ' Seiten') + ')';
    }
    html += '<div class="demo-extracted-note">' + escapeHtml(noteText) + '</div>';

    // The extracted text
    html += escapeHtml(data.extracted_text || '');
    return html;
  }

  // ==========================================
  // Main flow — single API call, progressive display
  // ==========================================
  async function startDemo() {
    if (activeTab === 'file') {
      return startFileDemo();
    }

    const text = inputEl.value.trim();
    if (!text) return;

    state = 'processing';
    startBtn.disabled = true;
    startBtn.innerHTML = '<div class="spinner" style="width:18px;height:18px;margin:0;border-width:2px;"></div> Verarbeite...';
    resetBtn.style.display = 'inline-flex';
    stepIndicator.style.display = 'flex';
    stepPanels.style.display = 'block';
    stepHint.style.display = 'flex';

    // Step 0: Show original text immediately
    document.getElementById('panel-0-content').innerHTML = escapeHtml(text);
    setStep(0);

    // Show loading hint for upcoming steps
    document.getElementById('panel-3-content').innerHTML = '<div class="spinner"></div><div class="loading-text">KI verarbeitet anonymisierten Text...</div>';

    try {
      // Single API call — gets all intermediate results
      const data = await callProcess(text, promptEl ? promptEl.value : '');
      processResult = data;
      analyzeResult = data;
      sessionId = data.session_id || null;

      const entities = data.entities || [];

      // === Sensitivity check — pause if sensitive ===
      if (hasSensitivityWarning(data)) {
        try {
          await buildSensitivityWarning(data.sensitivity);
        } catch (e) {
          // User clicked "Abbrechen"
          resetDemo();
          return;
        }
      }

      // === Step 1: Erkennung — pause so user can read ===
      await wait(800);
      document.getElementById('panel-1-content').innerHTML =
        data.annotated_html || buildAnnotatedHtml(text, entities);
      buildEntityLegend(entities);
      setStep(1);
      enableStepClick(1);

      // === Step 2: Anonymisierung — pause again ===
      await wait(1500);
      if (data.anonymized_text) {
        document.getElementById('panel-2-content').innerHTML = buildAnonymizedHtml(data.anonymized_text);
      }
      setStep(2);
      enableStepClick(2);

      // === Step 3: LLM-Antwort ===
      await wait(1500);
      if (data.llm_response_anonymized) {
        document.getElementById('panel-3-content').innerHTML = buildAnonymizedHtml(data.llm_response_anonymized);
      }
      setStep(3);
      enableStepClick(3);

      // === Step 4: Re-hydrierte Antwort ===
      await wait(2000);
      const rehydrated = data.llm_response_rehydrated || data.rehydrated_response;
      if (rehydrated) {
        const ents = entities.map(e => ({
          ...e,
          original_value: e.text || e.original_value
        }));
        document.getElementById('panel-4-content').innerHTML = buildRehydratedHtml(rehydrated, ents);
      } else {
        document.getElementById('panel-4-content').innerHTML = escapeHtml(data.llm_response_anonymized || 'Keine Antwort erhalten.');
      }

      setStep(4);
      enableStepClick(4);
      state = 'complete';
      startBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polyline points="20,6 9,17 4,12" fill="none" stroke="currentColor" stroke-width="3"/></svg> Fertig';

    } catch (err) {
      if (err.message === 'cancelled') return;
      state = 'error';
      const panelContent = document.getElementById('panel-' + currentStep + '-content');
      if (panelContent) {
        panelContent.innerHTML = '<div class="error-message">Fehler: ' + escapeHtml(err.message) + '</div>';
      }
      startBtn.innerHTML = 'Fehler — nochmal versuchen';
      startBtn.disabled = false;
      startBtn.onclick = function() {
        resetDemo();
        setTimeout(startDemo, 100);
      };
    }
  }

  // ==========================================
  // File upload flow
  // ==========================================
  async function startFileDemo() {
    if (!selectedFile) return;

    state = 'processing';
    startBtn.disabled = true;
    startBtn.innerHTML = '<div class="spinner" style="width:18px;height:18px;margin:0;border-width:2px;"></div> Datei wird verarbeitet...';
    resetBtn.style.display = 'inline-flex';
    stepIndicator.style.display = 'flex';
    stepPanels.style.display = 'block';
    stepHint.style.display = 'flex';

    // Step 0: Show loading while file is uploaded/extracted
    document.getElementById('panel-0-content').innerHTML = '<div class="spinner"></div><div class="loading-text">Datei wird hochgeladen und Text extrahiert...</div>';
    setStep(0);

    document.getElementById('panel-3-content').innerHTML = '<div class="spinner"></div><div class="loading-text">KI verarbeitet anonymisierten Text...</div>';

    try {
      const data = await callUpload(selectedFile, promptEl ? promptEl.value : '');
      processResult = data;
      analyzeResult = data;
      sessionId = data.session_id || null;

      const entities = data.entities || [];
      const extractedText = data.extracted_text || '';

      // === Step 0: Show extracted text with metadata warnings ===
      document.getElementById('panel-0-content').innerHTML = buildFileStep0(data);
      enableStepClick(0);

      // === Sensitivity check — pause if sensitive ===
      if (hasSensitivityWarning(data)) {
        try {
          await buildSensitivityWarning(data.sensitivity);
        } catch (e) {
          // User clicked "Abbrechen"
          resetDemo();
          return;
        }
      }

      // === Step 1: Erkennung ===
      await wait(800);
      document.getElementById('panel-1-content').innerHTML =
        data.annotated_html || buildAnnotatedHtml(extractedText, entities);
      buildEntityLegend(entities);
      setStep(1);
      enableStepClick(1);

      // === Step 2: Anonymisierung ===
      await wait(1500);
      if (data.anonymized_text) {
        document.getElementById('panel-2-content').innerHTML = buildAnonymizedHtml(data.anonymized_text);
      }
      setStep(2);
      enableStepClick(2);

      // === Step 3: LLM-Antwort ===
      await wait(1500);
      if (data.llm_response_anonymized) {
        document.getElementById('panel-3-content').innerHTML = buildAnonymizedHtml(data.llm_response_anonymized);
      }
      setStep(3);
      enableStepClick(3);

      // === Step 4: Re-hydrierte Antwort ===
      await wait(2000);
      const rehydrated = data.llm_response_rehydrated || data.rehydrated_response;
      if (rehydrated) {
        const ents = entities.map(e => ({
          ...e,
          original_value: e.text || e.original_value
        }));
        document.getElementById('panel-4-content').innerHTML = buildRehydratedHtml(rehydrated, ents);
      } else {
        document.getElementById('panel-4-content').innerHTML = escapeHtml(data.llm_response_anonymized || 'Keine Antwort erhalten.');
      }

      setStep(4);
      enableStepClick(4);
      state = 'complete';
      startBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polyline points="20,6 9,17 4,12" fill="none" stroke="currentColor" stroke-width="3"/></svg> Fertig';

    } catch (err) {
      if (err.message === 'cancelled') return;
      state = 'error';
      const panelContent = document.getElementById('panel-' + currentStep + '-content');
      if (panelContent) {
        panelContent.innerHTML = '<div class="error-message">Fehler: ' + escapeHtml(err.message) + '</div>';
      }
      startBtn.innerHTML = 'Fehler — nochmal versuchen';
      startBtn.disabled = false;
      startBtn.onclick = function() {
        resetDemo();
        setTimeout(startFileDemo, 100);
      };
    }
  }

  function resetDemo() {
    state = 'idle';
    currentStep = -1;
    sessionId = null;
    analyzeResult = null;
    processResult = null;

    inputEl.value = '';
    if (promptEl) promptEl.value = '';
    if (denylistEl) denylistEl.value = '';
    updateCharCount();

    // Clear file selection and switch to text tab
    clearFile();
    switchTab('text');

    sensitivityContainer.innerHTML = '';
    stepIndicator.style.display = 'none';
    stepPanels.style.display = 'none';
    stepHint.style.display = 'none';
    resetBtn.style.display = 'none';

    startBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5,3 19,12 5,21"/></svg> Analyse starten';
    startBtn.disabled = true;
    startBtn.onclick = startDemo;

    // Reset panels
    for (let i = 0; i < 5; i++) {
      const content = document.getElementById('panel-' + i + '-content');
      if (content) content.innerHTML = '';
    }

    // Reset step items
    const items = stepIndicator.querySelectorAll('.step-item');
    items.forEach(item => {
      item.classList.add('disabled');
      item.classList.remove('active', 'completed');
      item.style.pointerEvents = '';
      item.style.cursor = '';
    });
    stepIndicator.querySelectorAll('.step-connector').forEach(c => c.classList.remove('completed'));

    inputEl.focus();
  }

  // ==========================================
  // Event listeners
  // ==========================================
  inputEl.addEventListener('input', updateCharCount);

  optionsToggle.addEventListener('click', function() {
    const isOpen = optionsPanel.classList.toggle('open');
    optionsArrow.classList.toggle('open', isOpen);
  });

  startBtn.addEventListener('click', startDemo);
  resetBtn.addEventListener('click', resetDemo);

  // Tab switching
  tabBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      if (state !== 'idle') return;
      switchTab(this.dataset.tab);
    });
  });

  // Drag-and-drop handlers
  dropzone.addEventListener('click', function() {
    fileInput.click();
  });

  fileInput.addEventListener('change', function() {
    if (this.files && this.files[0]) {
      selectFile(this.files[0]);
    }
  });

  dropzone.addEventListener('dragenter', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.add('drag-over');
  });

  dropzone.addEventListener('dragover', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.add('drag-over');
  });

  dropzone.addEventListener('dragleave', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
  });

  dropzone.addEventListener('drop', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
    if (e.dataTransfer.files && e.dataTransfer.files[0]) {
      selectFile(e.dataTransfer.files[0]);
    }
  });

  fileRemove.addEventListener('click', clearFile);

  // Example buttons
  document.querySelectorAll('.example-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const idx = parseInt(this.dataset.example, 10);
      const ex = EXAMPLES[idx];
      if (ex) {
        if (state !== 'idle') resetDemo();
        // Make sure we're on the text tab
        switchTab('text');
        inputEl.value = ex.text;
        if (promptEl && ex.prompt) {
          promptEl.value = ex.prompt;
          optionsPanel.classList.add('open');
          optionsArrow.classList.add('open');
        }
        updateCharCount();
        inputEl.focus();
      }
    });
  });

  // Step indicator clicks
  stepIndicator.querySelectorAll('.step-item').forEach(item => {
    item.addEventListener('click', function() {
      const idx = parseInt(this.dataset.step, 10);
      if (!this.classList.contains('disabled')) {
        // Only switch panel view, don't change completed/active logic on the dots
        const panels = stepPanels.querySelectorAll('.step-panel');
        panels.forEach((p, i) => p.classList.toggle('active', i === idx));
      }
    });
  });

  // Init
  updateCharCount();
})();
</script>
