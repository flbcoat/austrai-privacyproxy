  }

  function showError(panelId, message) {
    const el = document.getElementById(panelId);
    if (el) {
      el.innerHTML = '<div class="error-message">' + escapeHtml(message) + '</div>';
    }
  }

  function buildAnnotatedHtml(text, entities) {
    if (!entities || entities.length === 0) return escapeHtml(text);

    // Sort entities by start position (descending) to replace from end
    const sorted = [...entities].sort((a, b) => b.start - a.start);
    let result = text;

    sorted.forEach(ent => {
      const before = result.slice(0, ent.start);
      const match = result.slice(ent.start, ent.end);
      const after = result.slice(ent.end);
      const cls = 'entity-mark entity-' + ent.entity_type;
      result = before + '<mark class="' + cls + '" title="' + ent.entity_type + '">' + escapeHtml(match) + '</mark>' + after;
    });

    // Escape remaining text segments (already handled by escaping match above)
    // Actually, we need to handle this differently — escape everything first, then insert marks
    // Let's redo with a forward approach:

    const sortedFwd = [...entities].sort((a, b) => a.start - b.start);
    let html = '';
    let pos = 0;

    sortedFwd.forEach(ent => {
      // Add text before this entity
      html += escapeHtml(text.slice(pos, ent.start));
      // Add the annotated entity
      const matchText = text.slice(ent.start, ent.end);
      const cls = 'entity-mark entity-' + ent.entity_type;
      html += '<mark class="' + cls + '" title="' + ent.entity_type + '">' + escapeHtml(matchText) + '</mark>';
      pos = ent.end;
    });

    // Remaining text
    html += escapeHtml(text.slice(pos));
    return html;
  }

  function buildEntityLegend(entities) {
    const types = new Set();
    entities.forEach(e => types.add(e.entity_type));
    const legend = document.getElementById('entity-legend');
    legend.innerHTML = '';

    types.forEach(type => {
      const info = ENTITY_COLORS[type] || { dot: '#94a3b8', label: type };
      const item = document.createElement('span');
      item.className = 'entity-legend-item';
      item.innerHTML = '<span class="entity-legend-dot" style="background:' + info.dot + '"></span>' + info.label;
      legend.appendChild(item);
    });
  }

  function buildAnonymizedHtml(anonymizedText) {
    // Replace placeholders like [PERSON_1] with styled spans
    return escapeHtml(anonymizedText).replace(/\[(\w+?)\]/g, function(match, name) {
      return '<span class="anon-placeholder">[' + name + ']</span>';
    });
  }

  function buildRehydratedHtml(rehydratedText, entities) {
    if (!entities || entities.length === 0) return escapeHtml(rehydratedText);

    // Find original values in the rehydrated text and highlight them
    let html = escapeHtml(rehydratedText);
    const uniqueValues = new Set();
    entities.forEach(ent => {
      if (ent.original_value) uniqueValues.add(ent.original_value);
    });

    uniqueValues.forEach(val => {
      const escaped = escapeHtml(val);
      if (escaped && escaped.length > 1) {
        const regex = new RegExp(escaped.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g');
        html = html.replace(regex, '<span class="rehydrated-mark">' + escaped + '</span>');
      }
    });

    return html;
  }

  // ==========================================
  // Sensitivity warning
  // ==========================================
  function buildSensitivityWarning(sensitivity) {
    return new Promise(function(resolve, reject) {
      var level = sensitivity.risk_level || 'medium';

      // Icon SVGs
      var iconSvg = level === 'high'
        ? '<svg class="sensitivity-warning-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>'
        : '<svg class="sensitivity-warning-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';

      var title = level === 'high'
        ? 'Hohe Sensibilit\u00e4t erkannt'
        : 'Erh\u00f6hte Sensibilit\u00e4t erkannt';

      // Build flags HTML
      var flagsHtml = '';
      if (sensitivity.flags && sensitivity.flags.length > 0) {
        flagsHtml = '<div class="sensitivity-flags">';
        sensitivity.flags.forEach(function(flag) {
          var scorePercent = Math.round((flag.score || 0) * 100);
          var excerpt = flag.excerpt || '';
          if (excerpt.length > 150) {
            excerpt = excerpt.slice(0, 147) + '...';
          }
          flagsHtml += '<div class="sensitivity-flag">';
          flagsHtml += '<div class="sensitivity-flag-top">';
          flagsHtml += '<span class="sensitivity-flag-label">' + escapeHtml(flag.label || flag.category) + '</span>';
          flagsHtml += '<span class="sensitivity-flag-score">' + scorePercent + '%</span>';
          flagsHtml += '</div>';
          if (excerpt) {
            flagsHtml += '<div class="sensitivity-excerpt" title="' + escapeHtml(excerpt) + '">' + escapeHtml(excerpt) + '</div>';
          }
          flagsHtml += '</div>';
        });
        flagsHtml += '</div>';
      }

      var html = '<div class="sensitivity-warning ' + level + '">';
      html += '<div class="sensitivity-warning-header">';
      html += iconSvg;
      html += '<div class="sensitivity-warning-title">' + escapeHtml(title) + '</div>';
      html += '</div>';
      if (sensitivity.summary) {
        html += '<div class="sensitivity-warning-summary">' + escapeHtml(sensitivity.summary) + '</div>';
      }
      html += flagsHtml;
      html += '<div class="sensitivity-actions">';
      html += '<button class="sensitivity-btn-proceed" id="sensitivity-proceed" type="button">Trotzdem fortfahren</button>';
      html += '<button class="sensitivity-btn-cancel" id="sensitivity-cancel" type="button">Abbrechen</button>';
      html += '</div>';
      html += '</div>';

      sensitivityContainer.innerHTML = html;

      document.getElementById('sensitivity-proceed').addEventListener('click', function() {
        sensitivityContainer.innerHTML = '';
        resolve();
      });

      document.getElementById('sensitivity-cancel').addEventListener('click', function() {
        sensitivityContainer.innerHTML = '';
        reject(new Error('cancelled'));
      });
    });
  }

  function hasSensitivityWarning(data) {
    return data.sensitivity
      && data.sensitivity.is_sensitive
      && data.sensitivity.risk_level !== 'low';
  }

  // ==========================================
