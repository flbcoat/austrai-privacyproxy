      '.tiff': 'TIFF-Bild', '.tif': 'TIFF-Bild', '.bmp': 'BMP-Bild', '.webp': 'WebP-Bild'
    };
    return labels[ext] || 'Datei';
  }

  function updateStartButton() {
    if (state !== 'idle') {
      startBtn.disabled = true;
      return;
    }
    if (activeTab === 'text') {
      startBtn.disabled = inputEl.value.length === 0;
    } else {
      startBtn.disabled = selectedFile === null;
