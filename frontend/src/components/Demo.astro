    if (len >= MAX_CHARS) charCountEl.classList.add('error');
    updateStartButton();
  }

  function setStep(idx) {
    currentStep = idx;
    if (idx > maxCompletedStep) maxCompletedStep = idx;

    var items = stepIndicator.querySelectorAll('.step-item');
    var connectors = stepIndicator.querySelectorAll('.step-connector');

    for (var i = 0; i < items.length; i++) {
      items[i].classList.remove('active', 'completed', 'disabled');
      if (i < idx) {
        items[i].classList.add('completed');
      } else if (i === idx) {
        items[i].classList.add('active');
      } else {
        items[i].classList.add('disabled');
      }
    }

    for (var c = 0; c < connectors.length; c++) {
      if (c < idx) {
        connectors[c].classList.add('completed');
      } else {
        connectors[c].classList.remove('completed');
      }
    }

    var panels = stepPanels.querySelectorAll('.step-panel');
    for (var p = 0; p < panels.length; p++) {
      if (p === idx) {
        panels[p].classList.add('active');
      } else {
        panels[p].classList.remove('active');
      }
    }
  }

