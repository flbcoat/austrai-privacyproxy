  function buildAnnotatedHtml(text, entities) {
    if (!entities || entities.length === 0) return escapeHtml(text);

    var sorted = entities.slice().sort(function(a, b) { return a.start - b.start; });
    var html = '';
    var pos = 0;

    for (var i = 0; i < sorted.length; i++) {
      var ent = sorted[i];
      if (ent.start < pos) continue;
      html += escapeHtml(text.slice(pos, ent.start));
      var matchText = text.slice(ent.start, ent.end);
      var cls = 'entity-mark entity-' + ent.entity_type;
      html += '<mark class="' + cls + '" title="' + escapeHtml(ent.entity_type) + '">' + escapeHtml(matchText) + '</mark>';
      pos = ent.end;
    }

    html += escapeHtml(text.slice(pos));
    return html;
  }

  function buildEntityLegend(entities) {
    var types = [];
    var seen = {};
    for (var i = 0; i < entities.length; i++) {
      var t = entities[i].entity_type;
      if (!seen[t]) {
        seen[t] = true;
        types.push(t);
      }
    }
    var legend = document.getElementById('entity-legend');
    legend.innerHTML = '';

    for (var j = 0; j < types.length; j++) {
      var info = ENTITY_COLORS[types[j]] || { dot: '#94a3b8', label: types[j] };
      var item = document.createElement('span');
      item.className = 'entity-legend-item';
      item.innerHTML = '<span class="entity-legend-dot" style="background:' + info.dot + '"></span>' + escapeHtml(info.label);
      legend.appendChild(item);
    }
  }

  function buildAnonymizedHtml(anonymizedText) {
    return escapeHtml(anonymizedText).replace(/\[(\w+?)\]/g, function(match, name) {
      return '<span class="anon-placeholder">[' + escapeHtml(name) + ']</span>';
    });
  }

  function buildRehydratedHtml(rehydratedText, entities) {
    if (!entities || entities.length === 0) return escapeHtml(rehydratedText);

    var html = escapeHtml(rehydratedText);
    var seen = {};
    for (var i = 0; i < entities.length; i++) {
      var val = entities[i].original_value;
      if (val && val.length > 1 && !seen[val]) {
        seen[val] = true;
        var escaped = escapeHtml(val);
        var pattern = escaped.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        html = html.replace(new RegExp(pattern, 'g'), '<span class="rehydrated-mark">' + escaped + '</span>');
      }
    }
    return html;
  }

