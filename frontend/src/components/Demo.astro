      html += '</div>';
    }

    var formatLabel = selectedFile ? getFileFormatLabel(selectedFile.name) : 'Datei';
    var noteText = formatLabel + ' verarbeitet';
    if (data.page_count) {
      noteText += ' (' + data.page_count + (data.page_count === 1 ? ' Seite' : ' Seiten') + ')';
    }
    html += '<div class="demo-extracted-note">' + escapeHtml(noteText) + '</div>';
    html += escapeHtml(data.extracted_text || '');
    return html;
  }

  // ==========================================
  // File validation & selection
  // ==========================================
  function validateFile(file) {
    var ext = getFileExtension(file.name);
    if (ACCEPTED_EXTENSIONS.indexOf(ext) === -1) {
      return 'Nicht unterst\u00fctztes Dateiformat: ' + ext + '. Erlaubt sind: ' + ACCEPTED_EXTENSIONS.join(', ');
    }
    if (file.size > MAX_FILE_SIZE) {
      return 'Datei ist zu gro\u00df (' + formatFileSize(file.size) + '). Maximum: 10 MB.';
    }
    if (file.size === 0) {
      return 'Die Datei ist leer.';
    }
    return null;
  }

  function selectFile(file) {
    var error = validateFile(file);
    if (error) {
      alert(error);
      return;
    }
    selectedFile = file;
    fileIcon.innerHTML = getFileTypeIcon(file.name);
    fileName.textContent = file.name;
    fileSize.textContent = formatFileSize(file.size);
    dropzone.style.display = 'none';
    fileInfo.style.display = 'flex';
    updateStartButton();
  }

  function clearFile() {
    selectedFile = null;
    fileInput.value = '';
    dropzone.style.display = '';
    fileInfo.style.display = 'none';
    updateStartButton();
  }

  // ==========================================
  // API calls
  // ==========================================
  function getDenyList() {
    if (!denylistEl) return null;
    var val = denylistEl.value.trim();
    if (!val) return null;
    var items = val.split('\n').map(function(s) { return s.trim(); }).filter(function(s) { return s.length > 0; });
    return items.length > 0 ? items : null;
  }

  function callProcess(text, prompt) {
    var body = { text: text };
    if (prompt && prompt.trim()) body.prompt = prompt.trim();
    var denyList = getDenyList();
    if (denyList) body.deny_list = denyList;

    return fetch(API_BASE + '/api/process', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    }).then(function(resp) {
      if (!resp.ok) {
        return resp.json().catch(function() { return {}; }).then(function(errData) {
          throw new Error(errData.detail || 'Verarbeitung fehlgeschlagen (HTTP ' + resp.status + ')');
        });
      }
      return resp.json();
    });
  }

  function callUpload(file, prompt) {
    var formData = new FormData();
    formData.append('file', file);
    if (prompt && prompt.trim()) formData.append('prompt', prompt.trim());
    var denyList = getDenyList();
    if (denyList) formData.append('deny_list', denyList.join('\n'));

    return fetch(API_BASE + '/api/upload', {
      method: 'POST',
      body: formData
    }).then(function(resp) {
      if (!resp.ok) {
        return resp.json().catch(function() { return {}; }).then(function(errData) {
          throw new Error(errData.detail || 'Dateiverarbeitung fehlgeschlagen (HTTP ' + resp.status + ')');
        });
      }
      return resp.json();
    });
  }

  // ==========================================
  // Shared step progression
  // ==========================================
  function runStepProgression(data, originalText) {
    var entities = data.entities || [];

    function doSensitivityCheck() {
      if (data.sensitivity && data.sensitivity.is_sensitive && data.sensitivity.risk_level === 'high') {
        return buildSensitivityWarning(data.sensitivity);
      }
      return Promise.resolve();
    }

    return doSensitivityCheck().then(function() {
      // Step 1: Erkennung
      return wait(800);
    }).then(function() {
      document.getElementById('panel-1-content').innerHTML =
        data.annotated_html || buildAnnotatedHtml(originalText, entities);
      buildEntityLegend(entities);
      setStep(1);
      enableStepClick(1);

      // Step 2: Anonymisierung
      return wait(1500);
    }).then(function() {
      if (data.anonymized_text) {
        document.getElementById('panel-2-content').innerHTML = buildAnonymizedHtml(data.anonymized_text);
      }
      setStep(2);
      enableStepClick(2);

      // Step 3: LLM-Antwort
      return wait(1500);
    }).then(function() {
      if (data.llm_response_anonymized) {
        document.getElementById('panel-3-content').innerHTML = buildAnonymizedHtml(data.llm_response_anonymized);
      }
      setStep(3);
      enableStepClick(3);

      // Step 4: Re-hydrierte Antwort
      return wait(2000);
    }).then(function() {
      var rehydrated = data.llm_response_rehydrated || '';
      if (rehydrated) {
        var ents = entities.map(function(e) {
          return {
            entity_type: e.entity_type,
            start: e.start,
            end: e.end,
            original_value: e.text || e.original_value
          };
        });
        document.getElementById('panel-4-content').innerHTML = buildRehydratedHtml(rehydrated, ents);
      } else {
        document.getElementById('panel-4-content').innerHTML = escapeHtml(data.llm_response_anonymized || 'Keine Antwort erhalten.');
      }

      setStep(4);
      enableStepClick(4);
      state = 'complete';
      startBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polyline points="20,6 9,17 4,12" fill="none" stroke="currentColor" stroke-width="3"/></svg> Fertig';
    });
  }

  // ==========================================
  // Main flow: Text mode
  // ==========================================
  function startDemo() {
    if (activeTab === 'file') {
      startFileDemo();
      return;
    }

    var text = inputEl.value.trim();
    if (!text) return;

    state = 'processing';
    startBtn.disabled = true;
    startBtn.innerHTML = '<div class="spinner" style="width:18px;height:18px;margin:0;border-width:2px;"></div> Verarbeite...';
    resetBtn.style.display = 'inline-flex';
    stepIndicator.style.display = 'flex';
    stepPanels.style.display = 'block';
    stepHint.style.display = 'flex';

    // Clear all panels first
    for (var i = 0; i < 5; i++) {
      var panel = document.getElementById('panel-' + i);
      if (panel) panel.classList.remove('active');
    }

    // Step 0: Show original text
    document.getElementById('panel-0-content').innerHTML = escapeHtml(text);
    document.getElementById('panel-3-content').innerHTML = '<div class="spinner"></div><div class="loading-text">KI verarbeitet anonymisierten Text...</div>';
    setStep(0);

    callProcess(text, promptEl ? promptEl.value : '').then(function(data) {
      sessionId = data.session_id || null;
      return runStepProgression(data, data.original_text || text);
    }).catch(function(err) {
      if (err.message === 'cancelled') {
        resetDemo();
        return;
      }
      state = 'error';
      var panelContent = document.getElementById('panel-' + Math.max(currentStep, 0) + '-content');
      if (panelContent) {
        panelContent.innerHTML = '<div class="error-message">Fehler: ' + escapeHtml(err.message) + '</div>';
      }
      startBtn.innerHTML = 'Fehler \u2014 nochmal versuchen';
      startBtn.disabled = false;
    });
  }

  // ==========================================
  // Main flow: File mode
  // ==========================================
  function startFileDemo() {
    if (!selectedFile) return;

    state = 'processing';
    startBtn.disabled = true;
    startBtn.innerHTML = '<div class="spinner" style="width:18px;height:18px;margin:0;border-width:2px;"></div> Datei wird verarbeitet...';
    resetBtn.style.display = 'inline-flex';
    stepIndicator.style.display = 'flex';
    stepPanels.style.display = 'block';
    stepHint.style.display = 'flex';

    // Clear all panels first
    for (var i = 0; i < 5; i++) {
      var panel = document.getElementById('panel-' + i);
      if (panel) panel.classList.remove('active');
    }

    // Step 0: Show loading
    document.getElementById('panel-0-content').innerHTML = '<div class="spinner"></div><div class="loading-text">Datei wird hochgeladen und Text extrahiert...</div>';
    document.getElementById('panel-3-content').innerHTML = '<div class="spinner"></div><div class="loading-text">KI verarbeitet anonymisierten Text...</div>';
    setStep(0);

    callUpload(selectedFile, promptEl ? promptEl.value : '').then(function(data) {
      sessionId = data.session_id || null;
      var extractedText = data.extracted_text || '';

      // Update Step 0 with extracted content
      document.getElementById('panel-0-content').innerHTML = buildFileStep0(data);
      enableStepClick(0);

      return runStepProgression(data, extractedText);
    }).catch(function(err) {
      if (err.message === 'cancelled') {
        resetDemo();
        return;
      }
      state = 'error';
      var panelContent = document.getElementById('panel-' + Math.max(currentStep, 0) + '-content');
      if (panelContent) {
        panelContent.innerHTML = '<div class="error-message">Fehler: ' + escapeHtml(err.message) + '</div>';
      }
      startBtn.innerHTML = 'Fehler \u2014 nochmal versuchen';
      startBtn.disabled = false;
    });
  }

  // ==========================================
  // Reset
  // ==========================================
  function resetDemo() {
    state = 'idle';
    currentStep = -1;
    maxCompletedStep = -1;
    sessionId = null;

    inputEl.value = '';
    if (promptEl) promptEl.value = '';
    if (denylistEl) denylistEl.value = '';
    updateCharCount();

    clearFile();
    switchTab('text');

    sensitivityContainer.innerHTML = '';
    stepIndicator.style.display = 'none';
    stepPanels.style.display = 'none';
    stepHint.style.display = 'none';
    resetBtn.style.display = 'none';

    startBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5,3 19,12 5,21"/></svg> Analyse starten';
    startBtn.disabled = true;

    // Clear all panel contents and remove active class
    for (var i = 0; i < 5; i++) {
      var content = document.getElementById('panel-' + i + '-content');
      if (content) content.innerHTML = '';
      var panel = document.getElementById('panel-' + i);
      if (panel) panel.classList.remove('active');
    }

    // Reset entity legend
    var legend = document.getElementById('entity-legend');
    if (legend) legend.innerHTML = '';

    // Reset step indicator items
    var items = stepIndicator.querySelectorAll('.step-item');
    for (var s = 0; s < items.length; s++) {
      items[s].classList.add('disabled');
      items[s].classList.remove('active', 'completed');
      items[s].style.pointerEvents = '';
      items[s].style.cursor = '';
    }
    var connectors = stepIndicator.querySelectorAll('.step-connector');
    for (var c = 0; c < connectors.length; c++) {
      connectors[c].classList.remove('completed');
    }

    inputEl.focus();
  }

  // ==========================================
  // Event listeners
  // ==========================================
  inputEl.addEventListener('input', updateCharCount);

  optionsToggle.addEventListener('click', function() {
    var isOpen = optionsPanel.classList.toggle('open');
    if (isOpen) {
      optionsArrow.classList.add('open');
    } else {
      optionsArrow.classList.remove('open');
    }
  });

  startBtn.addEventListener('click', function() {
    if (state === 'error') {
      resetDemo();
      setTimeout(startDemo, 100);
      return;
    }
    startDemo();
  });

  resetBtn.addEventListener('click', resetDemo);

  // Tab switching
  for (var t = 0; t < tabBtns.length; t++) {
    tabBtns[t].addEventListener('click', function() {
      if (state !== 'idle') return;
      switchTab(this.dataset.tab);
    });
  }

  // Drag-and-drop handlers
  dropzone.addEventListener('click', function() {
    fileInput.click();
  });

  fileInput.addEventListener('change', function() {
    if (this.files && this.files[0]) {
      selectFile(this.files[0]);
    }
  });

  dropzone.addEventListener('dragenter', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.add('drag-over');
  });

  dropzone.addEventListener('dragover', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.add('drag-over');
  });

  dropzone.addEventListener('dragleave', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
  });

  dropzone.addEventListener('drop', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
    if (e.dataTransfer.files && e.dataTransfer.files[0]) {
      selectFile(e.dataTransfer.files[0]);
    }
  });

  fileRemove.addEventListener('click', clearFile);

  // Example buttons
  var exampleBtns = document.querySelectorAll('.example-btn');
  for (var eb = 0; eb < exampleBtns.length; eb++) {
    exampleBtns[eb].addEventListener('click', function() {
      var idx = parseInt(this.dataset.example, 10);
      var ex = EXAMPLES[idx];
      if (ex) {
        if (state !== 'idle') resetDemo();
        switchTab('text');
        inputEl.value = ex.text;
        if (promptEl && ex.prompt) {
          promptEl.value = ex.prompt;
          optionsPanel.classList.add('open');
          optionsArrow.classList.add('open');
        }
        updateCharCount();
        inputEl.focus();
      }
    });
  }

  // Step indicator clicks — navigate between completed steps
  var stepItems = stepIndicator.querySelectorAll('.step-item');
  for (var si = 0; si < stepItems.length; si++) {
    stepItems[si].addEventListener('click', function() {
      var idx = parseInt(this.dataset.step, 10);
      if (this.classList.contains('disabled')) return;
      if (idx > maxCompletedStep) return;

      // Switch visible panel only
      var panels = stepPanels.querySelectorAll('.step-panel');
      for (var p = 0; p < panels.length; p++) {
        if (p === idx) {
          panels[p].classList.add('active');
        } else {
          panels[p].classList.remove('active');
        }
      }
    });
  }

  // Init
  updateCharCount();
})();
</script>
