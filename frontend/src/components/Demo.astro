---
---
<section class="section demo-section" id="demo">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Ausprobieren</span>
      <h2>Live-Demo</h2>
      <p>
        Teste PrivacyProxy mit echten österreichischen Beispieldaten — oder gib deinen eigenen Text ein.
        Klick dich nach der Analyse Schritt für Schritt durch die Pipeline.
      </p>
    </div>

    <div class="demo-wrapper">
      <!-- Privacy Notice -->
      <div class="demo-notice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <p>
          Diese Demo nutzt die <strong>Mistral API</strong> (EU-gehostet) zur Verarbeitung. Dein Text wird vorher anonymisiert — das LLM sieht nur Platzhalter, nie deine echten Daten. Session-Daten werden nach 30 Minuten automatisch gelöscht. Verwende trotzdem keine hochsensiblen Echtdaten, sondern nutze die Beispiele oder fiktive Texte.
        </p>
      </div>

      <!-- Input Area -->
      <div class="demo-input-area" id="demo-input-area">
        <div class="example-buttons" role="group" aria-label="Beispieltexte laden">
          <span class="example-label">Beispiele:</span>
          <button class="example-btn" data-example="0">Geschäfts-E-Mail</button>
          <button class="example-btn" data-example="1">Arzt-Befund</button>
          <button class="example-btn" data-example="2">Vertragsklausel</button>
        </div>

        <!-- Input Mode Tabs -->
        <div class="demo-tabs" id="demo-tabs">
          <button class="demo-tab active" data-tab="text" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            Text eingeben
          </button>
          <button class="demo-tab" data-tab="file" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Datei hochladen
          </button>
        </div>

        <!-- Tab Content: Text Input -->
        <div class="demo-tab-content active" id="tab-text">
          <label for="demo-input" class="sr-only">Text eingeben</label>
          <textarea
            id="demo-input"
            class="demo-textarea"
            placeholder="Gib hier einen Text mit sensiblen Daten ein..."
            maxlength="2000"
            rows="7"
          ></textarea>
          <div class="demo-char-count" id="demo-char-count">0 / 2000</div>
        </div>

        <!-- Tab Content: File Upload -->
        <div class="demo-tab-content" id="tab-file">
          <div class="demo-dropzone" id="demo-dropzone">
            <input type="file" id="demo-file-input" class="sr-only" accept=".pdf,.docx,.xlsx,.txt,.csv,.png,.jpg,.jpeg,.tiff,.tif,.bmp,.webp" />
            <div class="demo-dropzone-inner" id="demo-dropzone-inner">
              <svg class="demo-dropzone-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              <p class="demo-dropzone-text">Datei hierher ziehen oder <span class="demo-dropzone-link">klicken</span></p>
              <p class="demo-dropzone-formats">PDF, DOCX, XLSX, TXT, CSV, Bilder (PNG, JPG, TIFF, BMP, WebP)</p>
              <p class="demo-dropzone-limit">Max. 10 MB</p>
            </div>
          </div>
          <div class="demo-file-info" id="demo-file-info" style="display:none;">
            <div class="demo-file-icon" id="demo-file-icon"></div>
            <div class="demo-file-details">
              <span class="demo-file-name" id="demo-file-name"></span>
              <span class="demo-file-size" id="demo-file-size"></span>
            </div>
            <button class="demo-file-remove" id="demo-file-remove" type="button" title="Datei entfernen">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Entfernen
            </button>
          </div>
        </div>

        <!-- Erweiterte Optionen -->
        <div class="demo-options">
          <button class="demo-options-toggle" id="demo-options-toggle" type="button">
            <span class="arrow" id="options-arrow">&#9654;</span>
            Erweiterte Optionen
          </button>
          <div class="demo-options-panel" id="demo-options-panel">
            <div class="demo-option-group">
              <label for="demo-prompt" class="demo-option-label">
                System-Prompt
                <span class="demo-option-hint">Anweisung an das LLM, wie es antworten soll</span>
              </label>
              <textarea
                id="demo-prompt"
                placeholder="z.B. 'Fasse den folgenden Text zusammen' oder 'Beantworte diese E-Mail höflich'"
                rows="2"
              ></textarea>
            </div>
            <div class="demo-option-group">
              <label for="demo-denylist" class="demo-option-label">
                Zusätzliche Begriffe erkennen
                <span class="demo-option-hint">Firmen-, Projekt- oder Produktnamen die zusätzlich anonymisiert werden sollen (einer pro Zeile)</span>
              </label>
              <textarea
                id="demo-denylist"
                placeholder="z.B.&#10;Innovatech Solutions GmbH&#10;Projekt Phoenix&#10;AlpenCloud Pro"
                rows="3"
              ></textarea>
            </div>
          </div>
        </div>

        <div class="demo-actions">
          <button class="btn btn-primary btn-lg" id="demo-start-btn" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polygon points="5,3 19,12 5,21"/>
            </svg>
            Analyse starten
          </button>
          <button class="btn btn-secondary btn-sm" id="demo-reset-btn" style="display:none;">
            Neuer Text
          </button>
        </div>
      </div>

      <!-- Step Navigation Hint (shown after analysis) -->
      <div class="step-hint" id="step-hint" style="display:none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        Klicke auf die Schritte, um zwischen den einzelnen Phasen der Pipeline zu wechseln.
      </div>

      <!-- Step Indicator -->
      <div class="step-indicator" id="step-indicator" style="display:none;">
        <div class="step-item disabled" data-step="0">
          <div class="step-dot">1</div>
          <span class="step-label">Original</span>
        </div>
        <div class="step-connector"></div>
        <div class="step-item disabled" data-step="1">
          <div class="step-dot">2</div>
          <span class="step-label">Erkennung</span>
        </div>
        <div class="step-connector"></div>
        <div class="step-item disabled" data-step="2">
          <div class="step-dot">3</div>
          <span class="step-label">Anonymisiert</span>
        </div>
        <div class="step-connector"></div>
        <div class="step-item disabled" data-step="3">
          <div class="step-dot">4</div>
          <span class="step-label">LLM-Antwort</span>
        </div>
        <div class="step-connector"></div>
        <div class="step-item disabled" data-step="4">
          <div class="step-dot">5</div>
          <span class="step-label">Re-hydriert</span>
        </div>
      </div>

      <!-- Sensitivity Warning Container -->
      <div id="sensitivity-container"></div>

      <!-- Step Panels -->
      <div class="step-panels" id="step-panels" style="display:none;">
        <!-- Step 0: Original -->
        <div class="step-panel" id="panel-0">
          <div class="step-panel-header">
            <div class="step-panel-title">01 — Originaltext</div>
            <div class="step-panel-info">Dein eingegebener Text mit allen sensiblen Daten — so wie er normalerweise direkt an ein LLM gesendet werden würde.</div>
          </div>
          <div class="step-panel-content" id="panel-0-content"></div>
        </div>

        <!-- Step 1: Erkennung -->
        <div class="step-panel" id="panel-1">
          <div class="step-panel-header">
            <div class="step-panel-title">02 — Erkannte Entitäten</div>
            <div class="step-panel-info">Presidio + SpaCy analysieren den Text lokal und erkennen sensible Daten: Namen, IBANs, Telefonnummern, Sozialversicherungsnummern und mehr. Farbig markiert nach Typ.</div>
          </div>
          <div class="step-panel-content" id="panel-1-content"></div>
          <div class="entity-legend" id="entity-legend"></div>
        </div>

        <!-- Step 2: Anonymisiert -->
        <div class="step-panel" id="panel-2">
          <div class="step-panel-header">
            <div class="step-panel-title">03 — Anonymisierter Text</div>
            <div class="step-panel-info">Alle erkannten Entitäten werden durch typisierte Platzhalter ersetzt (z.B. [PERSON_1], [AT_IBAN_1]). <strong>Nur dieser Text wird an das LLM gesendet</strong> — deine echten Daten verlassen nie den Server.</div>
          </div>
          <div class="step-panel-content" id="panel-2-content"></div>
        </div>

        <!-- Step 3: LLM-Antwort -->
        <div class="step-panel" id="panel-3">
          <div class="step-panel-header">
            <div class="step-panel-title">04 — LLM-Antwort (anonymisiert)</div>
            <div class="step-panel-info">Die Antwort von Mistral AI — das Modell hat nur mit Platzhaltern gearbeitet und kennt deine echten Daten nicht. Beachte: Die Platzhalter tauchen in der Antwort wieder auf.</div>
          </div>
          <div class="step-panel-content" id="panel-3-content">
            <div class="spinner"></div>
            <div class="loading-text">KI verarbeitet anonymisierten Text...</div>
          </div>
        </div>

        <!-- Step 4: Re-hydriert -->
        <div class="step-panel" id="panel-4">
          <div class="step-panel-header">
            <div class="step-panel-title">05 — Re-hydrierte Antwort</div>
            <div class="step-panel-info">Die Platzhalter in der LLM-Antwort werden lokal wieder durch deine echten Daten ersetzt. Das Ergebnis: Eine vollständige, personalisierte Antwort — ohne dass das LLM jemals deine Daten gesehen hat.</div>
          </div>
          <div class="step-panel-content" id="panel-4-content"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-section {
    position: relative;
  }

  .demo-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .demo-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(6, 182, 212, 0.06);
    border: 1px solid rgba(6, 182, 212, 0.15);
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .demo-notice svg {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .demo-notice p {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: none;
  }

  .demo-notice strong {
    color: var(--color-text);
  }

  .step-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    padding: 0.75rem 1rem;
    margin-top: 1.5rem;
    font-size: 0.8125rem;
    color: var(--color-accent);
    background: rgba(6, 182, 212, 0.06);
    border-radius: var(--radius-md);
    animation: fadeSlideUp 0.4s ease both;
  }

  .step-hint svg {
    flex-shrink: 0;
  }

  .step-panel-header {
    margin-bottom: 1rem;
  }

  .step-panel-info {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-dim);
    margin-top: 0.4rem;
  }

  .step-panel-info strong {
    color: var(--color-accent);
  }

  .demo-input-area {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .demo-options {
    margin-top: 1rem;
  }

  .demo-options-toggle {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    padding: 0;
    background: none;
    border: none;
    transition: color var(--transition-fast);
  }

  .demo-options-toggle:hover {
    color: var(--color-accent);
  }

  .demo-options-toggle .arrow {
    transition: transform var(--transition-fast);
    display: inline-block;
    font-size: 0.7rem;
  }

  .demo-options-toggle .arrow.open {
    transform: rotate(90deg);
  }

  .demo-options-panel {
    overflow: hidden;
    max-height: 0;
    transition: max-height var(--transition-slow);
    padding-top: 0;
  }

  .demo-options-panel.open {
    max-height: 400px;
    padding-top: 1rem;
  }

  .demo-option-group {
    margin-bottom: 1rem;
  }

  .demo-option-group:last-child {
    margin-bottom: 0;
  }

  .demo-option-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .demo-option-hint {
    display: block;
    font-weight: 400;
    font-size: 0.75rem;
    color: var(--color-text-dim);
    margin-top: 0.15rem;
  }

  .demo-option-group textarea {
    width: 100%;
    padding: 0.65rem 0.85rem;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.5;
    resize: vertical;
    transition: border-color var(--transition-fast);
  }

  .demo-option-group textarea:focus {
    outline: none;
    border-color: var(--color-accent-purple);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
  }

  .example-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-dim);
    display: flex;
    align-items: center;
  }

  .demo-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  #demo-start-btn {
    transition: all var(--transition-base);
  }

  #demo-start-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  #demo-start-btn svg {
    fill: currentColor;
    stroke: none;
  }

  .step-panels {
    margin-top: 0;
  }

  /* Anonymized text styling */
  .anon-placeholder {
    display: inline;
    padding: 0.1em 0.4em;
    background: rgba(6, 182, 212, 0.15);
    color: var(--color-accent-light);
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 0.875em;
    font-weight: 600;
    border: 1px solid rgba(6, 182, 212, 0.25);
  }

  /* Re-hydrated highlight */
  .rehydrated-mark {
    background: rgba(16, 185, 129, 0.15);
    color: #34d399;
    padding: 0.1em 0.3em;
    border-radius: 3px;
    font-weight: 600;
    border-bottom: 2px solid #10b981;
  }

  /* ==========================================
     File Upload Tabs & Dropzone
     ========================================== */
  .demo-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1rem;
    border-bottom: 1.5px solid var(--color-border);
  }

  .demo-tab {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-dim);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    margin-bottom: -1.5px;
  }

  .demo-tab:hover {
    color: var(--color-text);
  }

  .demo-tab.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .demo-tab svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .demo-tab.active svg {
    opacity: 1;
  }

  .demo-tab-content {
    display: none;
  }

  .demo-tab-content.active {
    display: block;
  }

  .demo-dropzone {
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast);
    position: relative;
  }

  .demo-dropzone:hover {
    border-color: var(--color-accent);
    background: rgba(6, 182, 212, 0.03);
  }

  .demo-dropzone.drag-over {
    border-color: var(--color-accent);
    background: rgba(6, 182, 212, 0.06);
    box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.1);
  }

  .demo-dropzone-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    pointer-events: none;
  }

  .demo-dropzone-icon {
    color: var(--color-text-dim);
    margin-bottom: 0.25rem;
    transition: color var(--transition-fast);
  }

  .demo-dropzone:hover .demo-dropzone-icon,
  .demo-dropzone.drag-over .demo-dropzone-icon {
    color: var(--color-accent);
  }

  .demo-dropzone-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .demo-dropzone-link {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .demo-dropzone-formats {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    margin: 0;
  }

  .demo-dropzone-limit {
    font-size: 0.7rem;
    color: var(--color-text-dim);
    opacity: 0.7;
    margin: 0;
  }

  .demo-file-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-top: 0.75rem;
  }

  .demo-file-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
  }

  .demo-file-icon svg {
    width: 24px;
    height: 24px;
  }

  .demo-file-details {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .demo-file-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .demo-file-size {
    font-size: 0.7rem;
    color: var(--color-text-dim);
  }

  .demo-file-remove {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.6rem;
    font-size: 0.75rem;
    color: var(--color-text-dim);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    flex-shrink: 0;
  }

  .demo-file-remove:hover {
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.4);
  }

  .demo-metadata-warnings {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(251, 191, 36, 0.08);
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: var(--radius-sm);
    margin-bottom: 0.75rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: #fbbf24;
  }

  .demo-metadata-warnings svg {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .demo-extracted-note {
    font-size: 0.75rem;
    color: var(--color-text-dim);
    padding: 0.5rem 0.75rem;
    background: rgba(6, 182, 212, 0.05);
    border-radius: var(--radius-sm);
    margin-bottom: 0.5rem;
  }

  /* ==========================================
     Sensitivity Warning
     ========================================== */
  @keyframes sensitivitySlideIn {
    from {
      opacity: 0;
      transform: translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .sensitivity-warning {
    position: relative;
    margin: 1.25rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-border);
    border-radius: var(--radius-md);
    animation: sensitivitySlideIn 0.4s ease both;
  }

  .sensitivity-warning.medium {
    border-left-color: #f59e0b;
    background: rgba(245, 158, 11, 0.04);
  }

  .sensitivity-warning.high {
    border-left-color: #ef4444;
    background: rgba(239, 68, 68, 0.04);
  }

  .sensitivity-warning-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .sensitivity-warning-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
  }

  .sensitivity-warning.medium .sensitivity-warning-icon {
    color: #f59e0b;
  }

  .sensitivity-warning.high .sensitivity-warning-icon {
    color: #ef4444;
  }

  .sensitivity-warning-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .sensitivity-warning.medium .sensitivity-warning-title {
    color: #fbbf24;
  }

  .sensitivity-warning.high .sensitivity-warning-title {
    color: #f87171;
  }

  .sensitivity-warning-summary {
